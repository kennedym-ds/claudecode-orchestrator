{
  "name": "cc-github",
  "version": "2.0.0",
  "description": "GitHub integration — PR creation and review workflows, issue triage, branch management, and CI/CD status checks via GitHub MCP.",
  "author": "kennedym-ds",
  "license": "MIT",
  "components": {
    "agents": ".claude/agents/",
    "skills": ".claude/skills/",
    "commands": ".claude/commands/"
  },
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
